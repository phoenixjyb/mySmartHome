# Generated by scripts/generate_hitachi_ha_yaml.py
# READ-ONLY COMMISSIONING CONFIGURATION - verify addresses before enabling writes.
modbus:
  - name: hitachi_hvac
    type: rtuovertcp
    host: !secret hitachi_modbus_host
    port: !secret hitachi_modbus_port
    timeout: 5
    message_wait_milliseconds: 100
    sensors:
      - name: "日立转换器_室内机数量"
        unique_id: hitachi_converter_unit_count
        slave: !secret hitachi_modbus_slave
        address: 4997
        input_type: holding
        data_type: uint16
        scan_interval: 60
      - name: "日立转换器_可控状态"
        unique_id: hitachi_converter_ready_raw
        slave: !secret hitachi_modbus_slave
        address: 4998
        input_type: holding
        data_type: uint16
        scan_interval: 5
      - name: "日立室内机0_机种码"
        unique_id: hitachi_unit_0_model_code
        slave: !secret hitachi_modbus_slave
        address: 40016
        input_type: holding
        data_type: uint16
        scan_interval: 300
      - name: "日立室内机0_系统号"
        unique_id: hitachi_unit_0_system_no
        slave: !secret hitachi_modbus_slave
        address: 40026
        input_type: holding
        data_type: uint16
        scan_interval: 300
      - name: "日立室内机0_地址号"
        unique_id: hitachi_unit_0_indoor_address
        slave: !secret hitachi_modbus_slave
        address: 40027
        input_type: holding
        data_type: uint16
        scan_interval: 300
      - name: "日立室内机0_开关状态原始值"
        unique_id: hitachi_unit_0_power_status_raw
        slave: !secret hitachi_modbus_slave
        address: 40028
        input_type: holding
        data_type: uint16
        scan_interval: 10
      - name: "日立室内机0_模式状态原始值"
        unique_id: hitachi_unit_0_mode_status_raw
        slave: !secret hitachi_modbus_slave
        address: 40029
        input_type: holding
        data_type: uint16
        scan_interval: 10
      - name: "日立室内机0_风量状态原始值"
        unique_id: hitachi_unit_0_fan_status_raw
        slave: !secret hitachi_modbus_slave
        address: 40030
        input_type: holding
        data_type: uint16
        scan_interval: 10
      - name: "日立室内机0_设定温度整数"
        unique_id: hitachi_unit_0_set_temp_integer
        slave: !secret hitachi_modbus_slave
        address: 40031
        input_type: holding
        data_type: uint16
        scan_interval: 10
      - name: "日立室内机0_设定湿度原始值"
        unique_id: hitachi_unit_0_set_humidity_raw
        slave: !secret hitachi_modbus_slave
        address: 40032
        input_type: holding
        data_type: uint16
        scan_interval: 30
      - name: "日立室内机0_报警代码"
        unique_id: hitachi_unit_0_alarm_code
        slave: !secret hitachi_modbus_slave
        address: 40035
        input_type: holding
        data_type: uint16
        scan_interval: 10
      - name: "日立室内机0_设定温度半度标志"
        unique_id: hitachi_unit_0_set_temp_half_raw
        slave: !secret hitachi_modbus_slave
        address: 40037
        input_type: holding
        data_type: uint16
        scan_interval: 10
      - name: "日立室内机0_出风温度原始值"
