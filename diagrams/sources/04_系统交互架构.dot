digraph G {
  graph [rankdir=TB, bgcolor="white", pad=0.25, nodesep=0.35, ranksep=0.55, fontname="Noto Sans CJK SC", labelloc="t", label="跨系统交互架构 V3.2", fontsize=24];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=12, color="#607080", margin="0.18,0.10"];
  edge [fontname="Noto Sans CJK SC", fontsize=10, color="#657786", penwidth=1.3];

  triggers [label="触发与状态\n存在 / 温湿度 / CO₂ / 门磁 / 水浸\nModbus状态 / 用户按键 / 时间", fillcolor="#EEE8FA", color="#6F4EAA", penwidth=2];
  ha [label="Home Assistant 编排层\n条件判断、滞回、延时、权限、日志", fillcolor="#DDEAF7", color="#2474B5", penwidth=2];
  manual [label="原厂控制与实体按键\n始终保留", fillcolor="#FCE8E6", color="#C33A3A", penwidth=2];

  office [label="办公室舒适\n调整日立设定温度\nCO₂过高提醒", fillcolor="#EAF6ED"];
  humidity [label="中央加湿\n白天客厅+办公室\n夜间有人卧室\n开窗暂停", fillcolor="#E9F4F7"];
  bathroom [label="卫生间\n有人开灯\n湿度上升开排风\n回落后延时关闭", fillcolor="#E9F4F7"];
  cinema [label="观影模式\n关窗帘→调暗灯→投影/功放", fillcolor="#FFF2D8"];
  printing [label="P2S打印\n开排风→结束后延时\n高温/烟雾告警", fillcolor="#FFF2D8"];
  leak [label="漏水保护\n报警→通知→关闭总水阀", fillcolor="#E5F1FB"];
  away [label="离家模式\n关灯、暖通节能、扫地", fillcolor="#F2F4F7"];

  triggers -> ha;
  ha -> office; ha -> humidity; ha -> bathroom; ha -> cinema; ha -> printing; ha -> leak; ha -> away;
  manual -> office [style=dashed, label="原厂线控可接管"];
  manual -> humidity [style=dashed];
  manual -> bathroom [style=dashed, label="排风/灯可手动"];
  manual -> cinema [style=dashed, label="窗帘/灯实体按键"];
  manual -> printing [style=dashed, label="排风实体开关"];
  manual -> leak [style=dashed, label="阀门可手动"];
}
