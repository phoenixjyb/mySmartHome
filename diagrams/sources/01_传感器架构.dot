digraph G {
  graph [rankdir=TB, bgcolor="white", pad=0.25, nodesep=0.35, ranksep=0.55, fontname="Noto Sans CJK SC", labelloc="t", label="全屋传感器架构 V3.2", fontsize=24];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=12, color="#607080", penwidth=1.2, margin="0.18,0.10"];
  edge [fontname="Noto Sans CJK SC", fontsize=10, color="#657786", penwidth=1.3];

  subgraph cluster_safe {
    label="独立安全层（不依赖 Home Assistant）"; color="#D9534F"; style="rounded";
    smoke [label="烟雾报警\n客厅/储物间/Balcony1", fillcolor="#FCE8E6"];
    gas [label="燃气 / 一氧化碳报警", fillcolor="#FCE8E6"];
    electrical [label="断路器、漏保、设备原厂保护", fillcolor="#FCE8E6"];
    water_manual [label="总水阀手动操作", fillcolor="#FCE8E6"];
  }

  subgraph cluster_zigbee {
    label="Zigbee 本地传感器层"; color="#6F4EAA"; style="rounded";
    th [label="温湿度 × 8", fillcolor="#EEE8FA"];
    co2 [label="CO₂ × 2\nESPHome/LAN", fillcolor="#E9F4F7"];
    presence [label="人体/存在 × 7–8", fillcolor="#EAF6ED"];
    contact [label="门磁/窗磁", fillcolor="#EEE8FA"];
    leak [label="水浸 × 5–7", fillcolor="#E5F1FB"];
    airq [label="VOC/PM\nBalcony1 可后装", fillcolor="#E9F4F7"];
  }

  coordinator [label="PoE / Ethernet\nZigbee 协调器", fillcolor="#DDEAF7", color="#2474B5", penwidth=2];
  z2m [label="Zigbee2MQTT", fillcolor="#E8EDF5"];
  mqtt [label="Mosquitto MQTT", fillcolor="#E8EDF5"];
  ha [label="Home Assistant\n状态、自动化、仪表盘", fillcolor="#DCEBFA", color="#2474B5", penwidth=2];

  modbus [label="Modbus 状态\n日立空调 / 格恩加湿", fillcolor="#FFF2D8", color="#D28E1E"];
  meters [label="用水 / 用电 / UPS 状态", fillcolor="#FFF2D8"];

  actuators [label="执行器\n灯光、窗帘、排风、总水阀", fillcolor="#EAF6ED", color="#2E8B57", penwidth=2];
  notify [label="手机通知 / 历史记录", fillcolor="#F2F4F7"];

  th -> coordinator; presence -> coordinator; contact -> coordinator; leak -> coordinator;
  coordinator -> z2m -> mqtt -> ha;
  co2 -> ha [label="ESPHome / LAN"];
  airq -> ha [label="ESPHome / LAN"];
  modbus -> ha [label="RS-485→Ethernet"];
  meters -> ha;
  ha -> actuators [label="本地联动"];
  ha -> notify;
  smoke -> notify [style=dashed, label="可选状态接入"];
  gas -> notify [style=dashed, label="可选状态接入"];
}
