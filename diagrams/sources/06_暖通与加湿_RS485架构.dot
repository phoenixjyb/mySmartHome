digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.25, nodesep=0.4, ranksep=0.65, fontname="Noto Sans CJK SC", labelloc="t", label="暖通与中央加湿 RS-485 架构 V3.2", fontsize=24];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=12, color="#607080", margin="0.18,0.10"];
  edge [fontname="Noto Sans CJK SC", fontsize=10, color="#657786", penwidth=1.3];

  hitachi [label="日立多联机系统", fillcolor="#E8F2FC"];
  hconv [label="日立 Modbus / MiniModbus\n协议转换器\n点表已取得；串口参数待手册", fillcolor="#FFF2D8", color="#D28E1E", penwidth=2];
  discovery [label="发现与就绪\n4998=1 才可控\n4997=室内机数量\n4999=人工重新搜索", fillcolor="#EAF6ED", color="#2E8B57", penwidth=2];
  units [label="每台室内机 91 寄存器\nB=40000+91×Y\n状态 B+28…39\n控制 B+78…85", fillcolor="#E9F4F7"];

  gne [label="格恩中央加湿\n液晶控制器", fillcolor="#E9F4F7"];
  gneproto [label="Modbus RTU\nRS-485｜9600｜8N1\n湿度/水位/运行/故障", fillcolor="#EAF6ED", color="#2E8B57", penwidth=2];
  gateway [label="4路隔离型\nRS-485转Ethernet网关\n每路独立参数", fillcolor="#DDEAF7", color="#2474B5", penwidth=2];
  lan [label="Automation VLAN\n固定IP", fillcolor="#EEE8FA"];
  ha [label="Home Assistant\n只读发现→房间映射→安全写入", fillcolor="#DDEAF7", color="#2474B5", penwidth=2];
  sensors [label="房间独立传感器\n温湿度 + CO₂", fillcolor="#EEE8FA"];
  original [label="原厂线控器\n始终保留", fillcolor="#FCE8E6", color="#C33A3A"];
  daikin [label="大金 DTA120A611\n资料到达后再比较", fillcolor="#F2F4F7", style="rounded,dashed"];

  hitachi -> hconv [label="日立内部通信"];
  hconv -> discovery -> units;
  hconv -> gateway [label="Port 1\n预计RS-485"];
  gne -> gneproto -> gateway [label="Port 2"];
  gateway -> lan -> ha;
  units -> ha [dir=both, label="状态 / 控制"];
  sensors -> ha [label="Zigbee / ESPHome"];
  ha -> gneproto [dir=both, label="设定值 / 状态"];
  original -> hitachi [dir=both];
  original -> gne [dir=both];
  daikin -> gateway [style=dashed, label="Port 4预留"];
}
